# ============================================================
# Crypto Prediction Bot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Kalshi API
KALSHI_API_KEY=your_key_here
KALSHI_PRIVATE_KEY_PATH=./keys/kalshi.pem
KALSHI_ENV=demo                    # "demo" for paper trading, "prod" for live

# AI Models (all optional — bot works with any 1+)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AI...

# Risk Management (adjusted for $2K bankroll)
WALLET_SIZE_USD=2000
MAX_DAILY_LOSS_USD=200             # 10% of wallet
MAX_POSITIONS=10
MAX_TRADES_PER_DAY=50
MIN_EDGE_CENTS=5
MAX_SINGLE_TRADE_USD=100           # 5% of wallet

# Notifications (optional — uses ntfy.sh)
NTFY_TOPIC=my-crypto-bot

# Dashboard
DASHBOARD_PORT=8080
